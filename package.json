{
  "name": "emoticons",
  "version": "1.0.0",
  "description": "Generate random emoticons based on emotions",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js"
    }
  },
  "bin": {
    "emoticon": "./cli.js"
  },
  "scripts": {
    "demo": "node demo.js",
    "test": "node --test",
    "build:web": "esbuild index.js --bundle --outfile=dist/emoticon.js --format=iife --minify --global-name=emoticon",
    "playground": "npx serve ."
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "emotions.js",
    "cli.js",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "emoticon",
    "kaomoji",
    "emoji",
    "emotion",
    "text-face"
  ],
  "author": "Samim (https://github.com/ssmirr)",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
